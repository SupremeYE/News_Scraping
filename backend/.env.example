# 네이버 검색 API 자격증명
# https://developers.naver.com 에서 애플리케이션 등록 후 "검색" API 사용 설정 → Client ID/Secret 발급
# 아래 값을 실제 값으로 채운 뒤 이 파일을 .env 로 복사하세요.
NAVER_CLIENT_ID=your_client_id_here
NAVER_CLIENT_SECRET=your_client_secret_here

# (선택) 매일 자동 수집 시각. 24시간제 "HH:MM", 기본 08:00
DAILY_FETCH_TIME=08:00

# ---------- AI 뉴스 스터디(선택) ----------
# 뉴스 카드의 "AI 스터디"(요약/용어풀이/맥락/나에게의 의미, Q&A)에 쓰는 LLM 키.
# 없어도 앱은 동작하며, 키가 없으면 '프롬프트 복사'로 구독 챗(ChatGPT/Claude)에
# 붙여넣어 쓰는 무료 경로만 활성화된다.
OPENAI_API_KEY=your_openai_api_key_here
# (선택) 사용할 모델. 기본 gpt-4o-mini (개인 사용량이면 월 수백 원~1천 원대)
STUDY_MODEL=gpt-4o-mini
# (선택) LLM 프로바이더. 현재 openai 만 지원(추후 anthropic 등 확장 지점)
LLM_PROVIDER=openai
